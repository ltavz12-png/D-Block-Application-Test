# =============================================================================
# D Block Workspace - Staging Environment Variables
# =============================================================================
# Usage: terraform plan -var-file="environments/staging.tfvars"
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
environment  = "staging"
project_name = "dblock"
location     = "westeurope"

# -----------------------------------------------------------------------------
# Database - PostgreSQL Flexible Server
# -----------------------------------------------------------------------------
db_sku_name       = "B_Standard_B1ms"
db_storage_mb     = 32768
db_admin_username = "dblockadmin"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
redis_sku_name = "Basic"
redis_capacity = 0

# -----------------------------------------------------------------------------
# App Service
# -----------------------------------------------------------------------------
app_service_sku = "B1"
node_env        = "production"

# -----------------------------------------------------------------------------
# Notifications & Domain
# -----------------------------------------------------------------------------
admin_email = "it-product@adjaragroup.com"
domain_name = "dblock.ge"

# -----------------------------------------------------------------------------
# Tags
# -----------------------------------------------------------------------------
tags = {
  project     = "dblock"
  cost_center = "IT Product"
  team        = "D Block Engineering"
}
