# =============================================================================
# D Block Workspace - Production Environment Variables
# =============================================================================
# Usage: terraform plan -var-file="environments/production.tfvars"
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
environment  = "production"
project_name = "dblock"
location     = "westeurope"

# -----------------------------------------------------------------------------
# Database - PostgreSQL Flexible Server
# -----------------------------------------------------------------------------
db_sku_name       = "GP_Standard_D2s_v3"
db_storage_mb     = 65536
db_admin_username = "dblockadmin"

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
redis_sku_name = "Standard"
redis_capacity = 1

# -----------------------------------------------------------------------------
# App Service
# -----------------------------------------------------------------------------
app_service_sku = "P1v3"
node_env        = "production"

# -----------------------------------------------------------------------------
# Notifications & Domain
# -----------------------------------------------------------------------------
admin_email = "it-product@adjaragroup.com"
domain_name = "dblock.ge"

# -----------------------------------------------------------------------------
# Tags
# -----------------------------------------------------------------------------
tags = {
  project     = "dblock"
  cost_center = "IT Product"
  team        = "D Block Engineering"
}
